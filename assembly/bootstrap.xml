<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0
                              https://maven.apache.org/xsd/assembly-2.2.0.xsd">

    <!--
        Maven Assembly Descriptor：一体化启动包
        定义启动包的目录结构和文件映射关系。
        参见 specs/005-standalone-bootstrap/contracts/build-packaging.md
    -->

    <id>bootstrap</id>

    <formats>
        <!-- Windows 分发格式 -->
        <format>zip</format>
        <!-- Linux 分发格式 -->
        <format>tar.gz</format>
    </formats>

    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>alist-media-sync-${project.version}</baseDirectory>

    <!-- 文件集：将源文件映射到启动包目标路径 -->
    <fileSets>
        <!-- 启动脚本 -->
        <fileSet>
            <directory>${project.basedir}/scripts</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>start.sh</include>
                <include>start.bat</include>
                <include>diagnose.sh</include>
                <include>diagnose.bat</include>
            </includes>
            <fileMode>0755</fileMode>
            <lineEnding>unix</lineEnding>
        </fileSet>

        <!-- JRE 运行时（打包时由 exec-maven-plugin 下载到 target/runtime/） -->
        <fileSet>
            <directory>${project.build.directory}/runtime</directory>
            <outputDirectory>runtime/</outputDirectory>
            <excludes>
                <!-- 移除不必要的文件以减小体积 -->
                <exclude>**/man/**</exclude>
                <exclude>**/src.zip</exclude>
            </excludes>
        </fileSet>

        <!-- 配置文件 -->
        <fileSet>
            <directory>${project.basedir}/src/main/resources</directory>
            <outputDirectory>config/</outputDirectory>
            <includes>
                <include>application.yaml</include>
                <include>application.template.yaml</include>
            </includes>
        </fileSet>

        <!-- 空目录模板：data/ 和 logs/ -->
        <fileSet>
            <directory>${project.build.directory}/empty-dirs</directory>
            <outputDirectory>/</outputDirectory>
            <excludes>
                <exclude>**/*</exclude>
            </excludes>
        </fileSet>
    </fileSets>

    <!-- 依赖集：将项目 JAR 放入 lib/ 目录 -->
    <dependencySets>
        <dependencySet>
            <outputDirectory>lib</outputDirectory>
            <includes>
                <include>${project.groupId}:${project.artifactId}</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}-${artifact.version}.${artifact.extension}</outputFileNameMapping>
        </dependencySet>
    </dependencySets>

</assembly>
